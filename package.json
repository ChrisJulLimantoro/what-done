{
  "name": "wdid",
  "version": "0.1.0",
  "description": "What Did I Do Today? — LLM-powered standup summaries from Git and Claude Code sessions",
  "type": "module",
  "bin": {
    "wdid": "./dist/cli/index.js"
  },
  "main": "./dist/cli/index.js",
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs'); const f='dist/cli/index.js'; fs.writeFileSync(f, '#!/usr/bin/env node\\n' + fs.readFileSync(f,'utf8'))\" && chmod +x dist/cli/index.js",
    "build:watch": "tsc --watch",
    "dev": "node --loader ts-node/esm src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "standup",
    "git",
    "claude",
    "llm",
    "productivity",
    "cli",
    "developer-tools"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@google/generative-ai": "^0.21.0",
    "@iarna/toml": "^2.2.5",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "minimatch": "^10.0.1",
    "openai": "^4.58.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^22.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  }
}
